# Server configuration
PORT=3001
ALLOWED_ORIGINS=example.com,anotherdomain.com

# Authentication configuration
BETTER_AUTH_SECRET=dummy_better_auth_secret
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth configuration
GOOGLE_OAUTH_CLIENT_ID=dummy_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=dummy_google_oauth_client_secret

# Email Configuration (Replace with your Mailtrap/Ethereal credentials)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_test_user
SMTP_PASS=your_test_pass
SMTP_FROM='"News Digest" <noreply@news.com>'

# Cron Secret for securing the trigger endpoint
CRON_SECRET=my_super_secret_cron_key
